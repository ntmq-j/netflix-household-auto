{
  "botSettings": {
    "pageLoadTimeout": 90,
    "pollIntervalSeconds": 5,
    "errorRetryDelaySeconds": 15
  },
  "imapSettings": {
    "server": "[[IMAP_SERVER]]",
    "port": 993,
    "username": "[[IMAP_USERNAME]]",
    "password": "[[IMAP_PASSWORD]]",
    "maxEmailAge": 1800,
    "maxSearchResultsToFetch": 20,
    "folder": "[[IMAP_FOLDER]]"
  },
  "debugSettings": {
    "crashScreenshotFileName": "crash.png",
    "isDebugMode": false
  },
  "nuciLoggerSettings": {
      "minimumLevel": "Debug",
      "logFilePath": "logfile.log",
      "isFileOutputEnabled": true
  }
}
